{
  "1.1.0": "1.1.0",
  "description": "Bitwarden + direnv helper — sync secrets from Bitwarden into your shell environment",
  "homepage": "https://github.com/s1ks1/bwenv",
  "license": "MIT",
  "url": "https://github.com/s1ks1/bwenv/archive/refs/tags/v1.1.1.tar.gz",
  "hash": "0cd4437b6bc8cf526741d323c9c24702d90a2d675bc426b2e00db81c532c8bac",
  "extract_dir": "bwenv-1.1.0",
  "installer": {
    "script": [
      "New-Item -ItemType Directory -Force -Path \"$env:USERPROFILE\\.config\\direnv\\lib\" | Out-Null",
      "Copy-Item \"$dir\\setup\\bitwarden_folders.sh\" \"$env:USERPROFILE\\.config\\direnv\\lib\\bitwarden_folders.sh\"",
      "Copy-Item \"$dir\\setup\\bwenv.bat\" \"$dir\\bwenv.bat\""
    ]
  },
  "uninstaller": {
    "script": [
      "Remove-Item -Force -ErrorAction SilentlyContinue \"$env:USERPROFILE\\.config\\direnv\\lib\\bitwarden_folders.sh\""
    ]
  },
  "bin": "bwenv.bat",
  "checkver": "github",
  "autoupdate": {
    "url": "https://github.com/s1ks1/bwenv/archive/refs/tags/v$1.1.0.tar.gz"
  }
}


